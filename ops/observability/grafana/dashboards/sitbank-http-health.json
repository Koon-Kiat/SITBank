                },
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "sitbank-loki"
                      },
                      "group": "loki",
                      "kind": "DataQuery",
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(\r\n  count_over_time(\r\n    {source=\"nginx_access\", environment=~\"$environment\"}\r\n    | json\r\n    | status=~\"3..\"\r\n    [$__interval]\r\n  )\r\n) or vector(0)",
                        "legendFormat": "3xx",
                        "queryType": "range"
                      },
                      "version": "v0"
                    },
                    "refId": "B"
