                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(\r\n  count_over_time(\r\n    {source=\"nginx_access\", environment=~\"$environment\"}\r\n    | json\r\n    | __error__=\"\"\r\n    | status=~\"50[0234]\"\r\n    [$__range]\r\n  )\r\n) or vector(0)",
