                      },
                      "group": "loki",
                      "kind": "DataQuery",
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(\r\n  count_over_time(\r\n    {source=\"nginx_access\", environment=~\"$environment\"}\r\n    | json\r\n    | __error__=\"\"\r\n    | status=~\"40[34]\"\r\n    [$__range]\r\n  )\r\n) or vector(0)",
                        "queryType": "instant"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
