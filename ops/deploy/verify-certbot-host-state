#!/usr/bin/env bash
# Verify host-managed Certbot state without changing certificate material.
set -Eeuo pipefail

readonly LETSENCRYPT_ROOT="/etc/letsencrypt"
readonly PRODUCTION_PUBLIC_HOST="sitbank.pp.ua"
readonly -a PRODUCTION_PUBLIC_HOSTNAMES=("sitbank.pp.ua" "www.sitbank.pp.ua")
readonly STAGING_PUBLIC_HOST="staging-sitbank.pp.ua"
readonly -a STAGING_PUBLIC_HOSTNAMES=("staging-sitbank.pp.ua")
readonly CERTBOT_MIN_VALID_DAYS="${CERTBOT_MIN_VALID_DAYS:-14}"
readonly -a APPROVED_TLS_KEY_GROUPS=(root)

usage() {
    echo "Usage: verify-certbot-host-state [--renewal-dry-run] [production|staging]" >&2
}

if [[ "${EUID}" -ne 0 ]]; then
    echo "Run this host verification as root, for example: sudo $0 production" >&2
    exit 1
fi

target=""
renewal_dry_run=0
while [[ "$#" -gt 0 ]]; do
    case "$1" in
        production|staging)
            if [[ -n "${target}" ]]; then
                usage
                exit 2
            fi
            target="$1"
            ;;
        --renewal-dry-run)
            renewal_dry_run=1
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage
            exit 2
            ;;
    esac
    shift
done

if [[ -z "${target}" ]]; then
    usage
    exit 2
fi
if [[ ! "${CERTBOT_MIN_VALID_DAYS}" =~ ^[1-9][0-9]{0,3}$ ]] \
    || (( CERTBOT_MIN_VALID_DAYS > 3650 )); then
    echo "CERTBOT_MIN_VALID_DAYS must be an integer from 1 through 3650" >&2
    exit 2
fi
readonly CERTBOT_MIN_VALID_SECONDS=$((CERTBOT_MIN_VALID_DAYS * 86400))

failures=0

fail() {
    echo "ERROR: $*" >&2
    failures=1
}

verify_certbot() {
    if ! command -v certbot >/dev/null 2>&1; then
        fail "certbot is not installed"
        return
    fi
    echo "OK: certbot is installed"
}

verify_dns_cloudflare_plugin() {
    local plugins_output

    if ! plugins_output="$(certbot plugins 2>/dev/null)"; then
        fail "unable to list Certbot plugins"
        return
    fi
    if ! grep -Eq '(^|[[:space:]])dns-cloudflare([[:space:]]|$)' <<<"${plugins_output}"; then
        fail "Certbot dns-cloudflare plugin is not installed"
        return
    fi
    echo "OK: Certbot dns-cloudflare plugin is installed"
}

verify_renewal_timer() {
    if ! command -v systemctl >/dev/null 2>&1; then
        fail "systemctl is required to verify the host-managed certbot.timer"
        return
    fi
    if ! systemctl cat certbot.timer >/dev/null 2>&1; then
        fail "certbot.timer is not installed; configure and document an active Certbot renewal scheduler"
        return
    fi
    if ! systemctl is-enabled --quiet certbot.timer; then
        fail "certbot.timer is not enabled"
    fi
    if ! systemctl is-active --quiet certbot.timer; then
        fail "certbot.timer is not active"
    fi
    if [[ "${failures}" -eq 0 ]]; then
        echo "OK: certbot.timer is enabled and active"
    fi
}

verify_openssl() {
    if ! command -v openssl >/dev/null 2>&1; then
        fail "openssl is required to validate local TLS certificates"
        return
    fi
    echo "OK: openssl is installed"
}

certificate_covers_hostname() {
    local certificate_path="$1"
    local expected_hostname="$2"
    local san_output
    local san_entry

    if ! san_output="$(
        openssl x509 \
            -in "${certificate_path}" \
            -noout \
            -ext subjectAltName 2>/dev/null
    )"; then
        return 1
    fi

    # Require an exact DNS SAN. Deliberately do not fall back to the legacy
    # subject CN and do not treat a wildcard as an exact hostname match.
    while IFS= read -r san_entry; do
        san_entry="${san_entry#"${san_entry%%[![:space:]]*}"}"
        san_entry="${san_entry%"${san_entry##*[![:space:]]}"}"
        if [[ "${san_entry}" == "DNS:${expected_hostname}" ]]; then
            return 0
        fi
    done < <(printf '%s\n' "${san_output}" | tr ',' '\n')
    return 1
}

verify_certificate_file() {
    local cert_name="$1"
    local filename="$2"
    local expected_hostname="$3"
    local certificate_path="${LETSENCRYPT_ROOT}/live/${cert_name}/${filename}"
    local resolved_path
    local not_after

    if [[ ! -d "${LETSENCRYPT_ROOT}/live/${cert_name}" ]]; then
        fail "missing expected certificate directory: ${LETSENCRYPT_ROOT}/live/${cert_name}"
        return
    fi
    if [[ ! -e "${certificate_path}" || ! -f "${certificate_path}" ]]; then
        fail "missing expected certificate file: ${certificate_path}"
        return
    fi
    resolved_path="$(readlink -f -- "${certificate_path}" || true)"
    if [[ -z "${resolved_path}" || ! -f "${resolved_path}" ]]; then
        fail "certificate file does not resolve to a regular file: ${certificate_path}"
        return
    fi
    # Certbot live paths normally resolve into /etc/letsencrypt/archive. Requiring
    # that host-owned tree prevents repository-local or container-mounted material.
    if [[ "${resolved_path}" != "${LETSENCRYPT_ROOT}/"* ]]; then
        fail "certificate file resolves outside ${LETSENCRYPT_ROOT}: ${certificate_path}"
        return
    fi
    if ! command -v openssl >/dev/null 2>&1; then
        return
    fi
    if ! openssl x509 -in "${resolved_path}" -noout >/dev/null 2>&1; then
        fail "certificate is not parseable by openssl x509: ${certificate_path}"
        return
    fi
    if ! not_after="$(
        openssl x509 -in "${resolved_path}" -noout -enddate 2>/dev/null
    )" || [[ ! "${not_after}" =~ ^notAfter=.+$ ]]; then
        fail "certificate does not have a valid notAfter value: ${certificate_path}"
        return
    fi
    if ! openssl x509 \
        -in "${resolved_path}" \
        -noout \
        -checkend 0 >/dev/null 2>&1; then
        fail "certificate is expired (${not_after}): ${certificate_path}"
        return
    fi
    if ! openssl x509 \
        -in "${resolved_path}" \
        -noout \
        -checkend "${CERTBOT_MIN_VALID_SECONDS}" >/dev/null 2>&1; then
        fail "certificate expires within ${CERTBOT_MIN_VALID_DAYS} days (${not_after}): ${certificate_path}"
        return
    fi
    if ! certificate_covers_hostname "${resolved_path}" "${expected_hostname}"; then
        fail "certificate SAN does not exactly cover expected hostname ${expected_hostname}: ${certificate_path}"
        return
    fi
    echo "OK: ${certificate_path} is parseable, covers ${expected_hostname}, and remains valid beyond ${CERTBOT_MIN_VALID_DAYS} days"
}

is_approved_tls_key_group() {
    local candidate_group="$1"
    local approved_group

    for approved_group in "${APPROVED_TLS_KEY_GROUPS[@]}"; do
        if [[ "${candidate_group}" == "${approved_group}" ]]; then
            return 0
        fi
    done
    return 1
}

verify_private_key() {
    local domain="$1"
    local key_path="${LETSENCRYPT_ROOT}/live/${domain}/privkey.pem"
    local resolved_key_path
    local owner
    local group
    local mode
    local mode_value

    if [[ ! -e "${key_path}" || ! -f "${key_path}" ]]; then
        fail "missing expected private key: ${key_path}"
        return
    fi
    resolved_key_path="$(readlink -f -- "${key_path}" || true)"
    if [[ -z "${resolved_key_path}" || ! -f "${resolved_key_path}" ]]; then
        fail "private key does not resolve to a regular file: ${key_path}"
        return
    fi
    if [[ "${resolved_key_path}" != "${LETSENCRYPT_ROOT}/"* ]]; then
        fail "private key resolves outside ${LETSENCRYPT_ROOT}: ${key_path}"
        return
    fi

    owner="$(stat -c '%U' -- "${resolved_key_path}")"
    group="$(stat -c '%G' -- "${resolved_key_path}")"
    mode="$(stat -c '%a' -- "${resolved_key_path}")"
    if [[ "${owner}" != "root" ]]; then
        fail "private key must be owned by root: ${resolved_key_path} is owned by ${owner}"
    fi
    # This deployment uses host Nginx's privileged master process, so root is the
    # only approved TLS-key group. Add a reviewed, dedicated TLS group to the
    # explicit allowlist only when its membership and Nginx privilege model are documented.
    if ! is_approved_tls_key_group "${group}"; then
        fail "private key must be group-owned by an approved TLS group: ${resolved_key_path} is group-owned by ${group}"
    fi
    if [[ ! "${mode}" =~ ^[0-7]{3,4}$ ]]; then
        fail "private key mode is not an octal mode: ${resolved_key_path} has ${mode}"
        return
    fi
    mode_value=$((8#${mode}))
    if (( (mode_value & 0007) != 0 )); then
        fail "private key must not grant any permissions to other users (including world-readable or world-writable): ${resolved_key_path} has mode ${mode}"
    fi
    if (( (mode_value & 0022) != 0 )); then
        fail "private key must not be group-writable or world-writable: ${resolved_key_path} has mode ${mode}"
    fi
    if (( (mode_value & 0010) != 0 )); then
        fail "private key must not be group-executable: ${resolved_key_path} has mode ${mode}"
    fi
    if [[ "${failures}" -eq 0 ]]; then
        echo "OK: ${key_path} resolves to root:root mode ${mode}"
    fi
}

verify_renewal_dry_run() {
    local cert_name="$1"

    echo "Running explicit Certbot renewal dry-run for ${cert_name}; this may contact the ACME staging service."
    if ! certbot renew --dry-run --cert-name "${cert_name}"; then
        fail "certbot renewal dry-run failed for ${cert_name}"
        return
    fi
    echo "OK: certbot renewal dry-run passed for ${cert_name}"
}

case "${target}" in
    production)
        cert_name="${PRODUCTION_PUBLIC_HOST}"
        domains=("${PRODUCTION_PUBLIC_HOSTNAMES[@]}")
        ;;
    staging)
        cert_name="${STAGING_PUBLIC_HOST}"
        domains=("${STAGING_PUBLIC_HOSTNAMES[@]}")
        ;;
esac

verify_certbot
verify_dns_cloudflare_plugin
verify_openssl
verify_renewal_timer
for domain in "${domains[@]}"; do
    verify_certificate_file "${cert_name}" "fullchain.pem" "${domain}"
done
verify_private_key "${cert_name}"

if [[ "${renewal_dry_run}" -eq 1 && "${failures}" -eq 0 ]]; then
    verify_renewal_dry_run "${cert_name}"
fi

if [[ "${failures}" -ne 0 ]]; then
    echo "Certbot host-state verification failed for ${target}. No files were changed." >&2
    exit 1
fi

echo "Certbot host-state verification passed for ${target}."
if [[ "${renewal_dry_run}" -eq 0 ]]; then
    echo "Renewal dry-run was not requested. Run: sudo $0 --renewal-dry-run ${target}"
fi
