#!/usr/bin/env bash
set -Eeuo pipefail

readonly APP_ROOT="/var/www/scamcentre"
readonly RELEASES_DIR="${APP_ROOT}/releases"
readonly CURRENT_LINK="${APP_ROOT}/current"
readonly RUNTIME_ENV="/etc/scamcentre/runtime.env"
readonly SERVICE_NAME="scamcentre.service"
readonly SERVICE_USER="scamcentre"
readonly SERVICE_GROUP="scamcentre"
readonly DEPLOY_USER="scamcentre-deploy"
readonly INCOMING_DIR="/home/${DEPLOY_USER}/incoming"
readonly KEEP_RELEASES=5

exec 9>/var/lock/scamcentre-deploy.lock
if ! flock -n 9; then
    echo "Another deployment is already running" >&2
    exit 1
fi

release_sha="${1:-}"
public_host="${2:-}"

if [[ ! "${release_sha}" =~ ^[0-9a-f]{40}$ ]]; then
    echo "Invalid release SHA" >&2
    exit 2
fi
if [[ ! "${public_host}" =~ ^[A-Za-z0-9.-]+$ ]]; then
    echo "Invalid public host" >&2
    exit 2
fi

archive_path="${INCOMING_DIR}/scamcentre-${release_sha}.tar.gz"
checksum_path="${INCOMING_DIR}/scamcentre-${release_sha}.sha256"
runtime_env_path="${INCOMING_DIR}/runtime-${release_sha}.env"

for path in "${archive_path}" "${checksum_path}" "${runtime_env_path}"; do
    if [[ ! -f "${path}" || -L "${path}" ]]; then
        echo "Deployment inputs must be regular, non-symlink files" >&2
        exit 2
    fi
    if [[ "$(stat -c '%U' -- "${path}")" != "${DEPLOY_USER}" ]]; then
        echo "Deployment inputs must be owned by ${DEPLOY_USER}" >&2
        exit 2
    fi
done

release_dir="${RELEASES_DIR}/${release_sha}"
staging_dir="${RELEASES_DIR}/.${release_sha}.staging"
previous_release=""
switched_release=0
runtime_backup=""
runtime_replaced=0
release_created=0

cleanup_inputs() {
    rm -f -- "${archive_path}" "${checksum_path}" "${runtime_env_path}"
    if [[ -n "${runtime_backup}" ]]; then
        rm -f -- "${runtime_backup}"
    fi
    rm -rf -- "${staging_dir}"
}

rollback_release() {
    if [[ "${runtime_replaced}" -eq 1 ]]; then
        if [[ -n "${runtime_backup}" && -f "${runtime_backup}" ]]; then
            install -o root -g "${SERVICE_GROUP}" -m 0640 "${runtime_backup}" "${RUNTIME_ENV}"
        else
            rm -f -- "${RUNTIME_ENV}"
        fi
    fi
    if [[ "${switched_release}" -eq 1 && -n "${previous_release}" && -d "${previous_release}" ]]; then
        ln -sfn "${previous_release}" "${CURRENT_LINK}"
        systemctl restart "${SERVICE_NAME}" || true
    fi
    if [[ "${release_created}" -eq 1 && "$(readlink -f "${CURRENT_LINK}" 2>/dev/null || true)" != "${release_dir}" ]]; then
        rm -rf -- "${release_dir}"
    fi
}

trap cleanup_inputs EXIT
trap rollback_release ERR

install -d -m 0750 -o root -g "${SERVICE_GROUP}" "${APP_ROOT}" "${RELEASES_DIR}" /etc/scamcentre
chmod 0600 "${runtime_env_path}"

expected_checksum="$(awk 'NR == 1 { print $1 }' "${checksum_path}")"
actual_checksum="$(sha256sum "${archive_path}" | awk '{ print $1 }')"
if [[ ! "${expected_checksum}" =~ ^[0-9a-f]{64}$ || "${expected_checksum}" != "${actual_checksum}" ]]; then
    echo "Release checksum verification failed" >&2
    exit 1
fi

while IFS= read -r member; do
    case "${member}" in
        /*|..|../*|*/../*|*/..)
            echo "Unsafe archive member: ${member}" >&2
            exit 1
            ;;
    esac
done < <(tar -tzf "${archive_path}")

if [[ -e "${release_dir}" ]]; then
    echo "Release already exists: ${release_sha}" >&2
    exit 1
fi

rm -rf -- "${staging_dir}"
install -d -m 0750 -o "${SERVICE_USER}" -g "${SERVICE_GROUP}" "${staging_dir}"
runuser -u "${SERVICE_USER}" -- tar \
    --extract --gzip --file "${archive_path}" --directory "${staging_dir}" \
    --no-same-owner --no-same-permissions

for required_file in wsgi.py config.py requirements.lock migrations/alembic.ini; do
    if [[ ! -f "${staging_dir}/${required_file}" ]]; then
        echo "Release is missing ${required_file}" >&2
        exit 1
    fi
done

mv "${staging_dir}" "${release_dir}"
release_created=1

runuser -u "${SERVICE_USER}" -- python3.12 -m venv "${release_dir}/.venv"
runuser -u "${SERVICE_USER}" -- \
    "${release_dir}/.venv/bin/python" -m pip install --disable-pip-version-check \
        --require-hashes -r "${release_dir}/requirements.lock"

find "${release_dir}" -type d -exec chmod 0750 {} +
find "${release_dir}" -type f -exec chmod 0640 {} +
find "${release_dir}/.venv/bin" -type f -exec chmod 0750 {} +
chown -R root:"${SERVICE_GROUP}" "${release_dir}"

if [[ -f "${RUNTIME_ENV}" ]]; then
    runtime_backup="$(mktemp /etc/scamcentre/runtime.env.backup.XXXXXX)"
    cp --preserve=mode,ownership,timestamps -- "${RUNTIME_ENV}" "${runtime_backup}"
fi
install -o root -g "${SERVICE_GROUP}" -m 0640 "${runtime_env_path}" "${RUNTIME_ENV}"
runtime_replaced=1

systemctl start "scamcentre-check@${release_sha}.service"
systemctl start "scamcentre-migrate@${release_sha}.service"

if [[ -L "${CURRENT_LINK}" ]]; then
    previous_release="$(readlink -f "${CURRENT_LINK}")"
fi
ln -sfn "${release_dir}" "${CURRENT_LINK}"
switched_release=1
systemctl restart "${SERVICE_NAME}"

curl --fail --silent --show-error \
    --retry 12 --retry-delay 2 --retry-connrefused \
    --resolve "${public_host}:443:127.0.0.1" \
    "https://${public_host}/health/ready" >/dev/null

switched_release=0
runtime_replaced=0

mapfile -t old_releases < <(
    find "${RELEASES_DIR}" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' \
        | sort -rn \
        | awk -v keep="${KEEP_RELEASES}" 'NR > keep { print $2 }'
)
for old_release in "${old_releases[@]}"; do
    if [[ "${old_release}" != "$(readlink -f "${CURRENT_LINK}")" ]]; then
        rm -rf -- "${old_release}"
    fi
done

echo "Deployed ${release_sha}"
