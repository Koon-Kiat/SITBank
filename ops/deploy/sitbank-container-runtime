#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "${EUID}" -ne 0 ]]; then
    echo "Container runtime helper must run as root" >&2
    exit 1
fi

target="production"
if [[ "$#" -ge 2 && "${1:-}" =~ ^(staging|production)$ ]]; then
    target="${1}"
    shift
elif [[ "$#" -lt 1 ]]; then
    echo "Usage: sitbank-container-runtime [staging|production] command [options]" >&2
    exit 2
fi

case "${target}" in
    production)
        readonly DEPLOY_CONFIG="/etc/sitbank/deploy.conf"
        readonly COMPOSE_FILE="/opt/sitbank/compose.yml"
        readonly STATE_FILE="/var/lib/sitbank-container/current"
        readonly COMPOSE_PROJECT="sitbank"
        ;;
    staging)
        readonly DEPLOY_CONFIG="/etc/sitbank-staging/deploy.conf"
        readonly COMPOSE_FILE="/opt/sitbank-staging/compose.yml"
        readonly STATE_FILE="/var/lib/sitbank-staging-container/current"
        readonly COMPOSE_PROJECT="sitbank-staging"
        ;;
    *)
        echo "Runtime target must be staging or production" >&2
        exit 2
        ;;
esac

if [[ ! -r "${DEPLOY_CONFIG}" || ! -r "${STATE_FILE}" ]]; then
    echo "${target} container deployment state is not initialized" >&2
    exit 1
fi

# The validated root-owned deploy config path is selected by the wrapper.
# shellcheck disable=SC1090
source "${DEPLOY_CONFIG}"
image="$(awk -F= '$1 == "IMAGE" { print $2 }' "${STATE_FILE}")"
if [[ "${image}" != "${GHCR_REPOSITORY}@sha256:"* ]]; then
    echo "Stored image reference is invalid" >&2
    exit 1
fi

export SITBANK_IMAGE="${image}"

command="${1:-}"
shift

case "${command}" in
    up)
        [[ "$#" -eq 0 ]] || exit 2
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" \
            up --detach --no-build --pull never --remove-orphans
        ;;
    down)
        [[ "$#" -eq 0 ]] || exit 2
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" down --remove-orphans
        ;;
    check-security-alerts)
        [[ "$#" -eq 0 ]] || exit 2
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" \
            exec -T app python -m flask --app wsgi:app check-security-alerts
        ;;
    refresh-audit-log-anchor)
        [[ "$#" -eq 0 ]] || exit 2
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" \
            exec -T app python -m flask --app wsgi:app refresh-audit-log-anchor
        ;;
    retention-cleanup-report)
        [[ "$#" -eq 0 ]] || exit 2
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" \
            exec -T app python -m flask --app wsgi:app security run-retention-cleanup
        ;;
    rebaseline-security-alert-state)
        exec docker compose --project-name "${COMPOSE_PROJECT}" \
            --file "${COMPOSE_FILE}" \
            exec -T app python -m flask --app wsgi:app \
            rebaseline-security-alert-state "$@"
        ;;
    *)
        echo "Unsupported SITBank container runtime command" >&2
        exit 2
        ;;
esac
