#!/usr/bin/env bash
set -Eeuo pipefail

readonly DEPLOY_USER="sitbank-deploy"
readonly CONTAINER_GID="10001"
readonly CONTAINER_ACCOUNT="sitbank-container"
readonly COSIGN_VERSION="3.0.5"
readonly COSIGN_SHA256="db15cc99e6e4837daabab023742aaddc3841ce57f193d11b7c3e06c8003642b2"
readonly PRODUCTION_PUBLIC_HOST="sitbank.pp.ua"
readonly PRODUCTION_PUBLIC_WWW_HOST="www.sitbank.pp.ua"
readonly EDGE_DEFAULTS_FILE="/etc/nginx/conf.d/sitbank-default.conf"
readonly TLS_POLICY_FILE="/etc/nginx/snippets/sitbank-tls-policy.conf"
readonly STAGING_ACCESS_HEADERS_FILE="/etc/nginx/snippets/sitbank-cloudflare-access-headers.conf"
readonly PRODUCTION_RATE_LIMITS_FILE="/etc/nginx/conf.d/sitbank-production-rate-limits.conf"
readonly PRODUCTION_CLOUDFLARE_ORIGIN_PULL_CA_FILE="/etc/nginx/sitbank-production-cloudflare-origin-pull-ca.pem"
readonly PRODUCTION_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST="/etc/sitbank/cloudflare-origin-pull-ca-allowlist.json"
readonly STAGING_PUBLIC_HOST="staging-sitbank.pp.ua"
readonly STAGING_CLOUDFLARE_ORIGIN_PULL_CA_FILE="/etc/nginx/cloudflare-authenticated-origin-pull-ca.pem"
readonly STAGING_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST="/etc/sitbank-staging/cloudflare-origin-pull-ca-allowlist.json"
readonly STAGING_RATE_LIMITS_FILE="/etc/nginx/conf.d/sitbank-staging-rate-limits.conf"

if [[ "${EUID}" -ne 0 ]]; then
    echo "Run this bootstrap script as root" >&2
    exit 1
fi

target="production"
if [[ "${1:-}" == "production" || "${1:-}" == "staging" ]]; then
    target="$1"
    shift
fi

if [[ "$#" -lt 1 || "$#" -gt 3 ]]; then
    echo "Usage: bootstrap-container-ec2 [production|staging] OWNER/REPOSITORY [PUBLIC_HOST] [PUBLIC_BIND_ADDRESS]" >&2
    exit 2
fi
github_repository="${1:-}"
public_host="${2:-}"
public_bind_address="${3:-}"
if [[ ! "${github_repository}" =~ ^[A-Za-z0-9._-]+/[A-Za-z0-9._-]+$ ]]; then
    echo "Usage: bootstrap-container-ec2 [production|staging] OWNER/REPOSITORY [PUBLIC_HOST] [PUBLIC_BIND_ADDRESS]" >&2
    exit 2
fi
if [[ -z "${public_host}" ]]; then
    if [[ "${target}" == "production" ]]; then
        public_host="sitbank.pp.ua"
    else
        public_host="staging-sitbank.pp.ua"
    fi
fi
if [[ ! "${public_host}" =~ ^[A-Za-z0-9.-]+$ ]]; then
    echo "PUBLIC_HOST must be a bare hostname" >&2
    exit 2
fi
public_host_regex="${public_host//./\\.}"
if [[ "${target}" == "production" && "${public_host}" != "${PRODUCTION_PUBLIC_HOST}" ]]; then
    echo "Production PUBLIC_HOST must be ${PRODUCTION_PUBLIC_HOST}" >&2
    exit 2
fi
if [[ "${target}" == "staging" && "${public_host}" != "${STAGING_PUBLIC_HOST}" ]]; then
    echo "Staging PUBLIC_HOST must be ${STAGING_PUBLIC_HOST}" >&2
    exit 2
fi
case "${target}" in
    production)
        config_root="/etc/sitbank"
        compose_dir="/opt/sitbank"
        state_dir="/var/lib/sitbank-container"
        backup_dir="/var/backups/sitbank"
        compose_source="compose.prod.yml"
        systemd_source="ops/systemd/sitbank-container.service"
        systemd_service="sitbank-container.service"
        alert_systemd_service="sitbank-security-alerts.service"
        alert_systemd_timer="sitbank-security-alerts.timer"
        ;;
    staging)
        config_root="/etc/sitbank-staging"
        compose_dir="/opt/sitbank-staging"
        state_dir="/var/lib/sitbank-staging-container"
        backup_dir="/var/backups/sitbank-staging"
        compose_source="compose.staging.yml"
        systemd_source="ops/systemd/sitbank-staging-container.service"
        systemd_service="sitbank-staging-container.service"
        alert_systemd_service=""
        alert_systemd_timer=""
        ;;
esac

existing_deploy_config="${config_root}/deploy.conf"
if [[ -z "${public_bind_address}" && -f "${existing_deploy_config}" \
    && ! -L "${existing_deploy_config}" ]]; then
    public_bind_address="$(
        awk -F= '$1 == "PUBLIC_BIND_ADDRESS" { print $2; exit }' \
            "${existing_deploy_config}"
    )"
fi
if [[ -z "${public_bind_address}" ]]; then
    public_bind_address="$(
        ip -4 route get 1.1.1.1 \
            | awk '{ for (field_index = 1; field_index <= NF; field_index++) if ($field_index == "src") { print $(field_index + 1); exit } }'
    )"
fi
if ! python3 - "${public_bind_address}" <<'PY'
import ipaddress
import sys

try:
    address = ipaddress.ip_address(sys.argv[1])
except ValueError:
    raise SystemExit(1)
tailscale = ipaddress.ip_network("100.64.0.0/10")
if (
    address.version != 4
    or address.is_unspecified
    or address.is_loopback
    or address.is_link_local
    or address.is_multicast
    or address in tailscale
):
    raise SystemExit(1)
PY
then
    echo "PUBLIC_BIND_ADDRESS must be the non-Tailscale public-facing EC2/VPC IPv4 address" >&2
    exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
repository_lower="${github_repository,,}"

linux_runtime_files=(
    "${repo_root}/${compose_source}"
    "${repo_root}/${systemd_source}"
    "${repo_root}/ops/deploy/sitbank-container-bootstrap"
    "${repo_root}/ops/deploy/sitbank-observability-bootstrap"
    "${repo_root}/ops/deploy/sitbank-container-deploy"
    "${repo_root}/ops/deploy/sitbank-container-runtime"
    "${repo_root}/ops/systemd/sitbank-audit-anchor-refresh@.service"
    "${repo_root}/ops/systemd/sitbank-audit-anchor-refresh@.timer"
    "${repo_root}/ops/systemd/sitbank-retention-review@.service"
    "${repo_root}/ops/systemd/sitbank-retention-review@.timer"
    "${repo_root}/ops/deploy/sitbank-database-cutover"
    "${repo_root}/ops/deploy/verify-certbot-host-state"
    "${repo_root}/ops/deploy/verify-cloudflare-origin-pull-ca"
    "${repo_root}/ops/backups/sitbank-backup-encrypted"
    "${repo_root}/ops/backups/sitbank-restore-preflight"
    "${repo_root}/ops/nginx/sitbank-default.conf"
    "${repo_root}/ops/nginx/sitbank-cloudflare-access-headers.conf"
    "${repo_root}/ops/nginx/sitbank-tls-policy.conf"
    "${repo_root}/ops/security/cloudflare-origin-pull-ca-allowlist.json"
    "${repo_root}/ops/sudoers/sitbank-container-deploy"
    "${repo_root}/ops/sudoers/sitbank-observability-bootstrap"
)
if [[ "${target}" == "staging" ]]; then
    linux_runtime_files+=(
        "${repo_root}/ops/deploy/verify-staging-edge-boundary"
        "${repo_root}/ops/nginx-proxy-headers.conf"
        "${repo_root}/ops/nginx/sitbank-staging.conf"
        "${repo_root}/ops/nginx/sitbank-staging-rate-limits.conf"
        "${repo_root}/ops/postgres/init-sitbank-staging-roles.sh"
    )
else
    linux_runtime_files+=(
        "${repo_root}/ops/deploy/verify-production-nginx-boundary"
        "${repo_root}/ops/deploy/verify-tailscale-admin-access"
        "${repo_root}/ops/tailscale/install-tailscale"
        "${repo_root}/ops/tailscale/configure-admin-access"
        "${repo_root}/ops/tailscale/verify-admin-access"
        "${repo_root}/ops/nginx-proxy-headers.conf"
        "${repo_root}/ops/nginx/sitbank-production.conf"
        "${repo_root}/ops/nginx/sitbank-production-rate-limits.conf"
        "${repo_root}/ops/systemd/${alert_systemd_service}"
        "${repo_root}/ops/systemd/${alert_systemd_timer}"
    )
fi
for runtime_file in "${linux_runtime_files[@]}"; do
    if grep -q $'\r$' "${runtime_file}"; then
        echo "Refusing to install CRLF-formatted Linux file: ${runtime_file}" >&2
        echo "Recreate the bootstrap archive from a checkout honoring .gitattributes." >&2
        exit 1
    fi
done

if [[ "$(dpkg --print-architecture)" != "amd64" ]]; then
    echo "This deployment is pinned to linux/amd64" >&2
    exit 1
fi

apt-get update
apt-get install -y age ca-certificates curl gnupg openssl
if ! command -v docker >/dev/null 2>&1 \
    || ! docker compose version >/dev/null 2>&1; then
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        | gpg --dearmor --yes -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg
    # /etc/os-release is host-managed on the supported Ubuntu target.
    # shellcheck disable=SC1091
    . /etc/os-release
    printf '%s\n' \
        "deb [arch=amd64 signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu ${VERSION_CODENAME} stable" \
        > /etc/apt/sources.list.d/docker.list
    apt-get update
    apt-get install -y docker-ce docker-ce-cli containerd.io \
        docker-buildx-plugin docker-compose-plugin
fi
systemctl enable --now docker.service
apt-get install -y nginx certbot python3-certbot-nginx python3-certbot-dns-cloudflare

cosign_tmp="$(mktemp)"
trap 'rm -f -- "${cosign_tmp}"' EXIT
curl -fsSL \
    "https://github.com/sigstore/cosign/releases/download/v${COSIGN_VERSION}/cosign-linux-amd64" \
    -o "${cosign_tmp}"
printf '%s  %s\n' "${COSIGN_SHA256}" "${cosign_tmp}" | sha256sum --check --status
install -o root -g root -m 0755 "${cosign_tmp}" /usr/local/bin/cosign

existing_group="$(getent group "${CONTAINER_GID}" | cut -d: -f1 || true)"
if [[ -n "${existing_group}" && "${existing_group}" != "${CONTAINER_ACCOUNT}" ]]; then
    existing_group_members="$(
        getent group "${CONTAINER_GID}" | cut -d: -f4
    )"
    if [[ -n "${existing_group_members}" ]]; then
        echo "GID ${CONTAINER_GID} has supplementary members; refusing to rename it" >&2
        exit 1
    fi
    groupmod --new-name "${CONTAINER_ACCOUNT}" "${existing_group}"
fi
if [[ -z "${existing_group}" ]]; then
    groupadd --system --gid "${CONTAINER_GID}" "${CONTAINER_ACCOUNT}"
fi
existing_user="$(getent passwd 10001 | cut -d: -f1 || true)"
if [[ -n "${existing_user}" && "${existing_user}" != "${CONTAINER_ACCOUNT}" ]]; then
    existing_home="$(getent passwd 10001 | cut -d: -f6)"
    existing_shell="$(getent passwd 10001 | cut -d: -f7)"
    if [[ "${existing_home}" != "/nonexistent" \
        || "${existing_shell}" != "/usr/sbin/nologin" ]]; then
        echo "UID 10001 is not a locked container account; refusing to rename it" >&2
        exit 1
    fi
    usermod --login "${CONTAINER_ACCOUNT}" "${existing_user}"
fi
if [[ -z "${existing_user}" ]]; then
    useradd --system --uid 10001 --gid "${CONTAINER_GID}" \
        --home-dir /nonexistent --shell /usr/sbin/nologin \
        "${CONTAINER_ACCOUNT}"
fi
if ! id "${DEPLOY_USER}" >/dev/null 2>&1; then
    useradd --create-home --shell /bin/bash "${DEPLOY_USER}"
fi
gpasswd --delete "${DEPLOY_USER}" docker >/dev/null 2>&1 || true

install -d -o "${DEPLOY_USER}" -g "${DEPLOY_USER}" -m 0700 \
    "/home/${DEPLOY_USER}/.ssh" "/home/${DEPLOY_USER}/incoming"
touch "/home/${DEPLOY_USER}/.ssh/authorized_keys"
chown "${DEPLOY_USER}:${DEPLOY_USER}" \
    "/home/${DEPLOY_USER}/.ssh/authorized_keys"
chmod 0600 "/home/${DEPLOY_USER}/.ssh/authorized_keys"

install -d -o root -g root -m 0755 "${compose_dir}"
install -d -o root -g "${CONTAINER_GID}" -m 0750 "${config_root}"
install -d -o root -g "${CONTAINER_GID}" -m 0750 \
    "${config_root}/secrets"
install -d -o root -g root -m 0700 "${state_dir}" "${backup_dir}"
install -d -o "${CONTAINER_ACCOUNT}" -g "${CONTAINER_GID}" -m 0750 \
    "${state_dir}/security-alert-state"
if [[ "${target}" == "production" ]]; then
    install -d -o "${CONTAINER_ACCOUNT}" -g "${CONTAINER_GID}" -m 0750 \
        /var/lib/sitbank
fi

install -o root -g root -m 0644 \
    "${repo_root}/${compose_source}" "${compose_dir}/compose.yml"
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/sitbank-container-bootstrap" \
    /usr/local/sbin/sitbank-container-bootstrap
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/sitbank-observability-bootstrap" \
    /usr/local/sbin/sitbank-observability-bootstrap
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/sitbank-container-deploy" \
    /usr/local/sbin/sitbank-container-deploy
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/sitbank-container-runtime" \
    /usr/local/sbin/sitbank-container-runtime
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/sitbank-database-cutover" \
    /usr/local/sbin/sitbank-database-cutover
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/verify-certbot-host-state" \
    /usr/local/sbin/verify-certbot-host-state
install -o root -g root -m 0755 \
    "${repo_root}/ops/deploy/verify-cloudflare-origin-pull-ca" \
    /usr/local/sbin/verify-cloudflare-origin-pull-ca
if [[ "${target}" == "production" ]]; then
    install -o root -g root -m 0755 \
        "${repo_root}/ops/deploy/verify-production-nginx-boundary" \
        /usr/local/sbin/verify-production-nginx-boundary
    install -o root -g root -m 0755 \
        "${repo_root}/ops/deploy/verify-tailscale-admin-access" \
        /usr/local/sbin/verify-tailscale-admin-access
    install -o root -g root -m 0755 \
        "${repo_root}/ops/tailscale/install-tailscale" \
        /usr/local/sbin/sitbank-install-tailscale
    install -o root -g root -m 0755 \
        "${repo_root}/ops/tailscale/configure-admin-access" \
        /usr/local/sbin/sitbank-configure-tailscale-admin
    install -o root -g root -m 0755 \
        "${repo_root}/ops/tailscale/verify-admin-access" \
        /usr/local/sbin/sitbank-verify-tailscale-admin
fi
install -o root -g root -m 0755 \
    "${repo_root}/ops/backups/sitbank-backup-encrypted" \
    /usr/local/sbin/sitbank-backup-encrypted
install -o root -g root -m 0755 \
    "${repo_root}/ops/backups/sitbank-restore-preflight" \
    /usr/local/sbin/sitbank-restore-preflight
if [[ "${target}" == "staging" ]]; then
    install -o root -g root -m 0755 \
        "${repo_root}/ops/deploy/verify-staging-edge-boundary" \
        /usr/local/sbin/verify-staging-edge-boundary
    install -o root -g root -m 0644 \
        "${repo_root}/ops/security/cloudflare-origin-pull-ca-allowlist.json" \
        "${STAGING_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST}"
    install -d -o root -g root -m 0755 "${config_root}/postgres"
    install -o root -g root -m 0755 \
        "${repo_root}/ops/postgres/init-sitbank-staging-roles.sh" \
        "${config_root}/postgres/init-sitbank-staging-roles.sh"
else
    install -o root -g root -m 0644 \
        "${repo_root}/ops/security/cloudflare-origin-pull-ca-allowlist.json" \
        "${PRODUCTION_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST}"
fi
install -o root -g root -m 0644 \
    "${repo_root}/${systemd_source}" \
    "/etc/systemd/system/${systemd_service}"
for scheduled_unit in \
    sitbank-audit-anchor-refresh@.service \
    sitbank-audit-anchor-refresh@.timer \
    sitbank-retention-review@.service \
    sitbank-retention-review@.timer; do
    install -o root -g root -m 0644 \
        "${repo_root}/ops/systemd/${scheduled_unit}" \
        "/etc/systemd/system/${scheduled_unit}"
done
if [[ "${target}" == "production" ]]; then
    install -o root -g root -m 0644 \
        "${repo_root}/ops/systemd/${alert_systemd_service}" \
        "/etc/systemd/system/${alert_systemd_service}"
    install -o root -g root -m 0644 \
        "${repo_root}/ops/systemd/${alert_systemd_timer}" \
        "/etc/systemd/system/${alert_systemd_timer}"
fi
install -o root -g root -m 0440 \
    "${repo_root}/ops/sudoers/sitbank-container-deploy" \
    /etc/sudoers.d/sitbank-container-deploy
install -o root -g root -m 0440 \
    "${repo_root}/ops/sudoers/sitbank-observability-bootstrap" \
    /etc/sudoers.d/sitbank-observability-bootstrap

cat > "${config_root}/deploy.conf" <<EOF
GITHUB_REPOSITORY=${github_repository}
GHCR_REPOSITORY=ghcr.io/${repository_lower}
COSIGN_CERTIFICATE_IDENTITY=https://github.com/${github_repository}/.github/workflows/ci-deploy.yml@refs/heads/main
PUBLIC_HOST=${public_host}
PUBLIC_BIND_ADDRESS=${public_bind_address}
EOF
chown root:root "${config_root}/deploy.conf"
chmod 0644 "${config_root}/deploy.conf"

policy_file="${config_root}/common-passwords.txt"
if [[ -f "${policy_file}" ]]; then
    chown root:"${CONTAINER_GID}" "${policy_file}"
    chmod 0640 "${policy_file}"
fi

install_nginx_config() {
    local source_file="$1"
    local target_file="$2"
    local label="$3"
    local backup_prefix="$4"

    local rendered_source="${source_file}"
    local rendered_temp=""
    if grep -q "__SITBANK_PUBLIC_BIND_ADDRESS__" "${source_file}"; then
        rendered_temp="$(mktemp)"
        sed \
            "s/__SITBANK_PUBLIC_BIND_ADDRESS__/${public_bind_address}/g" \
            "${source_file}" > "${rendered_temp}"
        if grep -q "__SITBANK_PUBLIC_BIND_ADDRESS__" "${rendered_temp}"; then
            rm -f -- "${rendered_temp}"
            echo "Failed to render ${label}" >&2
            exit 1
        fi
        rendered_source="${rendered_temp}"
    fi

    if [[ -e "${target_file}" \
        && ( -L "${target_file}" || ! -f "${target_file}" ) ]]; then
        if [[ -n "${rendered_temp}" ]]; then
            rm -f -- "${rendered_temp}"
        fi
        echo "Refusing to replace unsafe ${label}: ${target_file}" >&2
        exit 1
    fi
    if [[ -f "${target_file}" ]] \
        && ! cmp -s "${rendered_source}" "${target_file}"; then
        install -o root -g root -m 0644 \
            "${target_file}" \
            "${backup_dir}/${backup_prefix}.$(date -u +%Y%m%dT%H%M%SZ).conf"
    fi
    install -o root -g root -m 0644 "${rendered_source}" "${target_file}"
    if [[ -n "${rendered_temp}" ]]; then
        rm -f -- "${rendered_temp}"
    fi
}

install_edge_default_site() {
    install_nginx_config \
        "${repo_root}/ops/nginx/sitbank-default.conf" \
        "${EDGE_DEFAULTS_FILE}" \
        "shared Nginx default config" \
        "nginx-sitbank-default"
}

install_tls_policy() {
    install_nginx_config \
        "${repo_root}/ops/nginx/sitbank-tls-policy.conf" \
        "${TLS_POLICY_FILE}" \
        "shared Nginx TLS policy" \
        "nginx-sitbank-tls-policy"
}

install_staging_access_headers() {
    install_nginx_config \
        "${repo_root}/ops/nginx/sitbank-cloudflare-access-headers.conf" \
        "${STAGING_ACCESS_HEADERS_FILE}" \
        "staging Cloudflare Access header policy" \
        "nginx-sitbank-cloudflare-access-headers"
}

refresh_enabled_sibling_site() {
    if [[ "${target}" == "production" \
        && -e /etc/nginx/sites-enabled/sitbank-staging ]]; then
        install_nginx_config \
            "${repo_root}/ops/nginx/sitbank-staging.conf" \
            /etc/nginx/sites-available/sitbank-staging \
            "staging Nginx config" \
            "nginx-sitbank-staging"
    elif [[ "${target}" == "staging" \
        && -e /etc/nginx/sites-enabled/sitbank ]]; then
        install_nginx_config \
            "${repo_root}/ops/nginx/sitbank-production.conf" \
            /etc/nginx/sites-available/sitbank \
            "production Nginx config" \
            "nginx-sitbank-production"
    fi
}

if [[ "${target}" == "production" ]]; then
    production_cert_dir="/etc/letsencrypt/live/${public_host}"
    if ! /usr/local/sbin/verify-cloudflare-origin-pull-ca \
        --certificate "${PRODUCTION_CLOUDFLARE_ORIGIN_PULL_CA_FILE}" \
        --allowlist "${PRODUCTION_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST}"; then
        echo "Production Cloudflare Authenticated Origin Pull CA validation failed." >&2
        echo "Install the reviewed production CA certificate before rerunning bootstrap." >&2
        exit 1
    fi
    for required_production_file in \
        "${production_cert_dir}/fullchain.pem" \
        "${production_cert_dir}/privkey.pem"; do
        if [[ ! -r "${required_production_file}" ]]; then
            echo "Missing required production TLS file: ${required_production_file}" >&2
            echo "Issue the production Certbot certificate before rerunning bootstrap." >&2
            exit 1
        fi
    done
    /usr/local/sbin/verify-certbot-host-state production

    nginx_conflict=0
    for production_hostname in \
        "${PRODUCTION_PUBLIC_HOST}" \
        "${PRODUCTION_PUBLIC_WWW_HOST}"; do
        production_hostname_regex="${production_hostname//./\\.}"
        while IFS= read -r enabled_site; do
            if [[ "$(readlink -f "${enabled_site}")" \
                != "/etc/nginx/sites-available/sitbank" ]]; then
                echo "Conflicting Nginx production site for ${production_hostname} is already enabled: ${enabled_site}" >&2
                nginx_conflict=1
            fi
        done < <(
            grep -RlE \
                "^[[:space:]]*server_name[[:space:]].*(^|[[:space:]])${production_hostname_regex}([[:space:];]|$)" \
                /etc/nginx/sites-enabled /etc/nginx/conf.d \
                2>/dev/null || true
        )
    done
    if [[ "${nginx_conflict}" -ne 0 ]]; then
        echo "Disable the duplicate production server block, then rerun bootstrap." >&2
        exit 1
    fi

    install -d -o root -g root -m 0755 /etc/nginx/snippets
    install -d -o root -g root -m 0755 /etc/nginx/conf.d
    install -d -o root -g root -m 0755 /var/www/certbot
    install_edge_default_site
    install_tls_policy
    install_staging_access_headers
    install -o root -g root -m 0644 \
        "${repo_root}/ops/nginx-proxy-headers.conf" \
        /etc/nginx/snippets/sitbank-proxy-headers.conf
    if [[ -e "${PRODUCTION_RATE_LIMITS_FILE}" \
        && ( -L "${PRODUCTION_RATE_LIMITS_FILE}" || ! -f "${PRODUCTION_RATE_LIMITS_FILE}" ) ]]; then
        echo "Refusing to replace unsafe production Nginx rate-limit file: ${PRODUCTION_RATE_LIMITS_FILE}" >&2
        exit 1
    fi
    if [[ -f "${PRODUCTION_RATE_LIMITS_FILE}" ]] \
        && ! cmp -s \
            "${repo_root}/ops/nginx/sitbank-production-rate-limits.conf" \
            "${PRODUCTION_RATE_LIMITS_FILE}"; then
        install -o root -g root -m 0644 \
            "${PRODUCTION_RATE_LIMITS_FILE}" \
            "${backup_dir}/nginx-sitbank-production-rate-limits.$(date -u +%Y%m%dT%H%M%SZ).conf"
    fi
    install -o root -g root -m 0644 \
        "${repo_root}/ops/nginx/sitbank-production-rate-limits.conf" \
        "${PRODUCTION_RATE_LIMITS_FILE}"

    production_site="/etc/nginx/sites-available/sitbank"
    install_nginx_config \
        "${repo_root}/ops/nginx/sitbank-production.conf" \
        "${production_site}" \
        "production Nginx config" \
        "nginx-sitbank-production"
    refresh_enabled_sibling_site
    ln -sfn "${production_site}" \
        /etc/nginx/sites-enabled/sitbank
    nginx -t
    systemctl reload nginx
    /usr/local/sbin/verify-production-nginx-boundary \
        --public-bind-address "${public_bind_address}"
fi

if [[ "${target}" == "staging" ]]; then
    staging_cert_dir="/etc/letsencrypt/live/${public_host}"
    "${repo_root}/ops/deploy/verify-staging-edge-boundary" \
        --edge-only "${public_host}"
    if ! /usr/local/sbin/verify-cloudflare-origin-pull-ca \
        --certificate "${STAGING_CLOUDFLARE_ORIGIN_PULL_CA_FILE}" \
        --allowlist "${STAGING_CLOUDFLARE_ORIGIN_PULL_CA_ALLOWLIST}"; then
        echo "Cloudflare Authenticated Origin Pull CA validation failed." >&2
        echo "Install a reviewed CA certificate before rerunning staging bootstrap." >&2
        exit 1
    fi
    for required_staging_file in \
        "${staging_cert_dir}/fullchain.pem" \
        "${staging_cert_dir}/privkey.pem"; do
        if [[ ! -r "${required_staging_file}" ]]; then
            echo "Missing required staging TLS file: ${required_staging_file}" >&2
            echo "Issue the staging Certbot certificate before rerunning bootstrap." >&2
            exit 1
        fi
    done
    /usr/local/sbin/verify-certbot-host-state staging
    nginx_conflict=0
    while IFS= read -r enabled_site; do
        if [[ "$(readlink -f "${enabled_site}")" \
            != "/etc/nginx/sites-available/sitbank-staging" ]]; then
            echo "Conflicting Nginx staging site is already enabled: ${enabled_site}" >&2
            nginx_conflict=1
        fi
    done < <(
        grep -RlE \
            "^[[:space:]]*server_name[[:space:]].*(^|[[:space:]])${public_host_regex}([[:space:];]|$)" \
            /etc/nginx/sites-enabled /etc/nginx/conf.d \
            2>/dev/null || true
    )
    if [[ "${nginx_conflict}" -ne 0 ]]; then
        echo "Disable the duplicate staging server block, then rerun bootstrap." >&2
        exit 1
    fi

    install -d -o root -g root -m 0755 /etc/nginx/snippets
    install -d -o root -g root -m 0755 /etc/nginx/conf.d
    install -d -o root -g root -m 0755 /var/www/certbot
    install_edge_default_site
    install_tls_policy
    install_staging_access_headers
    install -o root -g root -m 0644 \
        "${repo_root}/ops/nginx-proxy-headers.conf" \
        /etc/nginx/snippets/sitbank-proxy-headers.conf
    if [[ -e "${STAGING_RATE_LIMITS_FILE}" \
        && ( -L "${STAGING_RATE_LIMITS_FILE}" || ! -f "${STAGING_RATE_LIMITS_FILE}" ) ]]; then
        echo "Refusing to replace unsafe staging Nginx rate-limit file: ${STAGING_RATE_LIMITS_FILE}" >&2
        exit 1
    fi
    if [[ -f "${STAGING_RATE_LIMITS_FILE}" ]] \
        && ! cmp -s \
            "${repo_root}/ops/nginx/sitbank-staging-rate-limits.conf" \
            "${STAGING_RATE_LIMITS_FILE}"; then
        install -o root -g root -m 0644 \
            "${STAGING_RATE_LIMITS_FILE}" \
            "${backup_dir}/nginx-sitbank-staging-rate-limits.$(date -u +%Y%m%dT%H%M%SZ).conf"
    fi
    install -o root -g root -m 0644 \
        "${repo_root}/ops/nginx/sitbank-staging-rate-limits.conf" \
        "${STAGING_RATE_LIMITS_FILE}"

    staging_site="/etc/nginx/sites-available/sitbank-staging"
    install_nginx_config \
        "${repo_root}/ops/nginx/sitbank-staging.conf" \
        "${staging_site}" \
        "staging Nginx config" \
        "nginx-sitbank-staging"
    refresh_enabled_sibling_site
    ln -sfn "${staging_site}" \
        /etc/nginx/sites-enabled/sitbank-staging
    nginx -t
    systemctl reload nginx
fi

if [[ -S /var/run/docker.sock ]]; then
    chmod 0660 /var/run/docker.sock
fi
if ss -lnt | grep -Eq ':(2375|2376)([[:space:]]|$)'; then
    echo "Docker API must not be exposed over TCP" >&2
    exit 1
fi

visudo -cf /etc/sudoers.d/sitbank-container-deploy
visudo -cf /etc/sudoers.d/sitbank-observability-bootstrap
systemctl daemon-reload
systemctl enable "${systemd_service}"
systemctl enable --now "sitbank-audit-anchor-refresh@${target}.timer"
systemctl enable --now "sitbank-retention-review@${target}.timer"
if [[ "${target}" == "production" ]]; then
    systemctl enable --now "${alert_systemd_timer}"
fi

echo "${target^} container bootstrap complete; existing production containers were not restarted."
echo "Seed ${config_root} with unique runtime secrets and policy files before deployment."
