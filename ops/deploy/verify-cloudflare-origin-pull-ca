#!/usr/bin/env python3
"""Verify the host-managed Cloudflare Authenticated Origin Pull CA."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import stat
# OpenSSL is invoked without a shell and with a fixed argument structure.
import subprocess  # nosec B404
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


DEFAULT_CERTIFICATE = Path(
    "/etc/nginx/cloudflare-authenticated-origin-pull-ca.pem"
)
DEFAULT_ALLOWLIST = Path(
    "/etc/sitbank-staging/cloudflare-origin-pull-ca-allowlist.json"
)
MAX_CERTIFICATE_BYTES = 64 * 1024
MAX_ALLOWLIST_BYTES = 64 * 1024
PEM_CERTIFICATE_PATTERN = re.compile(
    rb"\A-----BEGIN CERTIFICATE-----\r?\n"
    rb"(?:[A-Za-z0-9+/]{1,64}={0,2}\r?\n)+"
    rb"-----END CERTIFICATE-----\r?\n?\Z"
)
FINGERPRINT_PATTERN = re.compile(r"^[0-9A-F]{64}$")


class OriginPullCAVerificationError(RuntimeError):
    """Raised when local AOP trust material is unsafe or unexpected."""


@dataclass(frozen=True)
class FileMetadata:
    is_regular: bool
    is_symlink: bool
    owner: str
    group: str
    mode: int


@dataclass(frozen=True)
class CertificateDetails:
    fingerprint: str
    subject: str
    issuer: str
    not_before: datetime
    not_after: datetime


@dataclass(frozen=True)
class AllowlistEntry:
    fingerprint: str
    subject: str
    issuer: str
    description: str


def _normalize_fingerprint(value: str) -> str:
    normalized = value.replace(":", "").strip().upper()
    if not FINGERPRINT_PATTERN.fullmatch(normalized):
        raise OriginPullCAVerificationError(
            "Fingerprint allowlist contains an invalid SHA-256 fingerprint"
        )
    return normalized


def _read_metadata(path: Path) -> FileMetadata:
    try:
        file_stat = path.lstat()
    except FileNotFoundError as exc:
        raise OriginPullCAVerificationError(f"Required file is missing: {path}") from exc
    except OSError as exc:
        raise OriginPullCAVerificationError(f"Required file cannot be inspected: {path}") from exc

    try:
        import grp
        import pwd

        owner = pwd.getpwuid(file_stat.st_uid).pw_name
        group = grp.getgrgid(file_stat.st_gid).gr_name
    except ImportError as exc:
        raise OriginPullCAVerificationError(
            "POSIX account metadata is required for CA verification"
        ) from exc
    except KeyError as exc:
        raise OriginPullCAVerificationError(
            f"Required file has an unknown owner or group: {path}"
        ) from exc

    return FileMetadata(
        is_regular=stat.S_ISREG(file_stat.st_mode),
        is_symlink=stat.S_ISLNK(file_stat.st_mode),
        owner=owner,
        group=group,
        mode=stat.S_IMODE(file_stat.st_mode),
    )


def _validate_certificate_metadata(metadata: FileMetadata) -> None:
    if metadata.is_symlink:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file must not be a symlink"
        )
    if not metadata.is_regular:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA path must be a regular file"
        )
    if metadata.owner != "root":
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file must be owned by root"
        )
    if metadata.group not in {"root", "www-data"}:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file group must be root or www-data"
        )

    approved_modes = (
        {0o600, 0o640, 0o644}
        if metadata.group == "root"
        else {0o600, 0o640}
    )
    if metadata.mode not in approved_modes:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file mode must be 0600/0640, "
            "or 0644 only when group-owned by root"
        )
    if metadata.mode & (stat.S_IWGRP | stat.S_IWOTH):
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file must not be group/world-writable"
        )


def _validate_allowlist_metadata(metadata: FileMetadata) -> None:
    if metadata.is_symlink or not metadata.is_regular:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA allowlist must be a regular non-symlink file"
        )
    if metadata.owner != "root" or metadata.group != "root":
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA allowlist must be owned by root:root"
        )
    if metadata.mode not in {0o600, 0o640, 0o644}:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA allowlist mode must be 0600, 0640, or 0644"
        )
    if metadata.mode & (stat.S_IWGRP | stat.S_IWOTH):
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA allowlist must not be group/world-writable"
        )


def _read_single_pem_certificate(path: Path) -> None:
    try:
        contents = path.read_bytes()
    except OSError as exc:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file cannot be read"
        ) from exc
    if not contents or len(contents) > MAX_CERTIFICATE_BYTES:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file is empty or too large"
        )
    if not PEM_CERTIFICATE_PATTERN.fullmatch(contents):
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA file must contain exactly one PEM certificate"
        )


def _load_allowlist(path: Path) -> tuple[AllowlistEntry, ...]:
    try:
        raw = path.read_bytes()
    except OSError as exc:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA fingerprint allowlist cannot be read"
        ) from exc
    if not raw or len(raw) > MAX_ALLOWLIST_BYTES:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA fingerprint allowlist is empty or too large"
        )
    try:
        payload: Any = json.loads(raw)
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA fingerprint allowlist is invalid JSON"
        ) from exc
    if (
        not isinstance(payload, dict)
        or payload.get("schema") != 1
        or not isinstance(payload.get("certificates"), list)
        or not payload["certificates"]
    ):
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA fingerprint allowlist has an invalid schema"
        )

    entries: list[AllowlistEntry] = []
    fingerprints: set[str] = set()
    for item in payload["certificates"]:
        if not isinstance(item, dict):
            raise OriginPullCAVerificationError(
                "Cloudflare origin-pull CA fingerprint allowlist entry is invalid"
            )
        fingerprint = _normalize_fingerprint(str(item.get("sha256_fingerprint", "")))
        subject = str(item.get("subject", "")).strip()
        issuer = str(item.get("issuer", "")).strip()
        description = str(item.get("description", "")).strip()
        if not subject or not issuer or not description:
            raise OriginPullCAVerificationError(
                "Cloudflare origin-pull CA allowlist entries require subject, "
                "issuer, and description"
            )
        if fingerprint in fingerprints:
            raise OriginPullCAVerificationError(
                "Cloudflare origin-pull CA allowlist contains duplicate fingerprints"
            )
        fingerprints.add(fingerprint)
        entries.append(
            AllowlistEntry(
                fingerprint=fingerprint,
                subject=subject,
                issuer=issuer,
                description=description,
            )
        )
    return tuple(entries)


def _openssl_certificate_details(path: Path) -> CertificateDetails:
    openssl = shutil.which("openssl")
    if not openssl:
        raise OriginPullCAVerificationError("openssl is required for CA verification")

    try:
        # The executable is resolved from PATH and every argument is fixed or a
        # local path supplied by the root-only bootstrap.
        result = subprocess.run(  # nosec B603
            [
                openssl,
                "x509",
                "-in",
                os.fspath(path),
                "-noout",
                "-subject",
                "-issuer",
                "-fingerprint",
                "-sha256",
                "-startdate",
                "-enddate",
                "-nameopt",
                "RFC2253",
                "-ext",
                "basicConstraints",
                "-checkend",
                "0",
            ],
            check=False,
            capture_output=True,
            text=True,
            timeout=10,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        raise OriginPullCAVerificationError(
            "openssl could not validate the Cloudflare origin-pull CA"
        ) from exc
    if result.returncode != 0:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA is unparsable, expired, or not yet valid"
        )

    subject = ""
    issuer = ""
    fingerprint = ""
    not_before_text = ""
    not_after_text = ""
    for line in result.stdout.splitlines():
        stripped = line.strip()
        if stripped.startswith("subject="):
            subject = stripped.removeprefix("subject=").strip()
        elif stripped.startswith("issuer="):
            issuer = stripped.removeprefix("issuer=").strip()
        elif "Fingerprint=" in stripped:
            fingerprint = stripped.split("Fingerprint=", 1)[1].strip()
        elif stripped.startswith("notBefore="):
            not_before_text = stripped.removeprefix("notBefore=").strip()
        elif stripped.startswith("notAfter="):
            not_after_text = stripped.removeprefix("notAfter=").strip()
    if "CA:TRUE" not in result.stdout.replace(" ", ""):
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull trust certificate must be a CA certificate"
        )
    if (
        not subject
        or not issuer
        or not fingerprint
        or not not_before_text
        or not not_after_text
    ):
        raise OriginPullCAVerificationError(
            "openssl did not return complete origin-pull CA details"
        )
    try:
        not_before = datetime.strptime(
            not_before_text,
            "%b %d %H:%M:%S %Y %Z",
        ).replace(tzinfo=timezone.utc)
        not_after = datetime.strptime(
            not_after_text,
            "%b %d %H:%M:%S %Y %Z",
        ).replace(tzinfo=timezone.utc)
    except ValueError as exc:
        raise OriginPullCAVerificationError(
            "openssl returned invalid origin-pull CA validity dates"
        ) from exc
    now = datetime.now(timezone.utc)
    if now < not_before or now >= not_after:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA is not currently valid"
        )
    return CertificateDetails(
        fingerprint=_normalize_fingerprint(fingerprint),
        subject=subject,
        issuer=issuer,
        not_before=not_before,
        not_after=not_after,
    )


def verify_origin_pull_ca(
    certificate_path: Path,
    allowlist_path: Path,
) -> tuple[CertificateDetails, AllowlistEntry]:
    _validate_certificate_metadata(_read_metadata(certificate_path))
    _validate_allowlist_metadata(_read_metadata(allowlist_path))
    _read_single_pem_certificate(certificate_path)
    entries = _load_allowlist(allowlist_path)
    details = _openssl_certificate_details(certificate_path)

    entry = next(
        (
            candidate
            for candidate in entries
            if candidate.fingerprint == details.fingerprint
        ),
        None,
    )
    if entry is None:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA fingerprint is not in the reviewed allowlist"
        )
    if details.subject != entry.subject or details.issuer != entry.issuer:
        raise OriginPullCAVerificationError(
            "Cloudflare origin-pull CA subject or issuer does not match its "
            "reviewed allowlist entry"
        )
    return details, entry


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--certificate",
        type=Path,
        default=DEFAULT_CERTIFICATE,
    )
    parser.add_argument(
        "--allowlist",
        type=Path,
        default=DEFAULT_ALLOWLIST,
    )
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(sys.argv[1:] if argv is None else argv)
    try:
        details, entry = verify_origin_pull_ca(
            args.certificate,
            args.allowlist,
        )
    except OriginPullCAVerificationError as exc:
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1
    print(
        "Verified Cloudflare origin-pull CA: "
        f"{entry.description}; SHA256={details.fingerprint}"
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
