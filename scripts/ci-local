#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
DOCKER_SKIP_MESSAGE = (
    "Docker is unavailable; skipped Docker/Compose-only local checks. "
    "Local validation is partial."
)

SEMGREP_CONFIGS = (
    "p/python",
    "p/flask",
    "p/security-audit",
    "p/owasp-top-ten",
    "p/github-actions",
)
STATIC_ANALYSIS_EXCLUDES = (
    ".venv",
    "venv",
    ".pytest_cache",
    ".pytest-tmp",
    "coverage",
    "htmlcov",
    "node_modules",
    "dist",
    "build",
)

PYTHON_CHECKS = (
    (
        "Full parallel test suite",
        (
            sys.executable,
            "-m",
            "pytest",
            "-q",
            "-n",
            "auto",
            "--durations=30",
            "--durations-min=0.5",
        ),
    ),
    ("Compile Python sources", (sys.executable, "-m", "compileall", "app", "config.py", "wsgi.py", "admin_wsgi.py")),
    ("Package consistency", (sys.executable, "-m", "pip", "check")),
    (
        "Bandit high-confidence scan",
        (sys.executable, "-m", "bandit", "-q", "-ll", "-r", "app", "ops", "config.py", "wsgi.py", "admin_wsgi.py"),
    ),
    (
        "Runtime dependency audit",
        (sys.executable, "-m", "pip_audit", "--disable-pip", "--require-hashes", "-r", "requirements.lock"),
    ),
    (
        "Dev dependency audit",
        (sys.executable, "-m", "pip_audit", "--disable-pip", "--require-hashes", "-r", "requirements-dev.lock"),
    ),
    (
        "Dependency lock validation",
        (sys.executable, "ops/security/check_dependency_locks.py"),
    ),
    (
        "Repository secret scan",
        (sys.executable, "ops/security/scan_repository_secrets.py", "--history"),
    ),
    ("Whitespace check", ("git", "diff", "--check")),
)


@dataclass(frozen=True)
class CheckResult:
    name: str
    status: str
    detail: str = ""


def section(name: str) -> None:
    print(f"\n== {name} ==", flush=True)


def record_result(
    results: list[CheckResult],
    name: str,
    status: str,
    detail: str = "",
) -> None:
    results.append(CheckResult(name=name, status=status, detail=detail))
    suffix = f" — {detail}" if detail else ""
    stream = sys.stderr if status == "FAIL" else sys.stdout
    print(f"{status}: {name}{suffix}", file=stream, flush=True)


def run(
    name: str,
    command: tuple[str, ...] | list[str],
    results: list[CheckResult],
) -> None:
    print(f"\n-- {name}", flush=True)
    print("+ " + " ".join(command), flush=True)
    try:
        subprocess.run(command, cwd=REPO_ROOT, check=True)
    except (FileNotFoundError, subprocess.CalledProcessError) as exc:
        record_result(results, name, "FAIL", str(exc))
        raise
    record_result(results, name, "PASS")


def discover_lint_targets(kind: str) -> list[str]:
    result = subprocess.run(
        [
            sys.executable,
            "ops/security/discover_lint_targets.py",
            kind,
        ],
        cwd=REPO_ROOT,
        check=True,
        capture_output=True,
        text=True,
    )
    targets = [line for line in result.stdout.splitlines() if line]
    if not targets:
        raise RuntimeError(f"No {kind} lint targets were discovered.")
    return targets


def run_optional_static_analysis(results: list[CheckResult]) -> bool:
    shell_targets = discover_lint_targets("shell")
    dockerfiles = discover_lint_targets("dockerfile")
    checks = (
        (
            "ShellCheck repository shell scripts",
            "shellcheck",
            ["--severity=style", *shell_targets],
            ".github/workflows/shellcheck.yml",
        ),
        (
            "Hadolint repository Dockerfiles",
            "hadolint",
            ["--failure-threshold", "style", *dockerfiles],
            ".github/workflows/hadolint.yml",
        ),
        (
            "Semgrep high-severity SAST",
            "semgrep",
            [
                "scan",
                *[
                    item
                    for config in SEMGREP_CONFIGS
                    for item in ("--config", config)
                ],
                "--severity",
                "ERROR",
                "--error",
                *[
                    item
                    for excluded in STATIC_ANALYSIS_EXCLUDES
                    for item in ("--exclude", excluded)
                ],
                ".",
            ],
            ".github/workflows/semgrep.yml",
        ),
    )

    for name, tool, arguments, workflow in checks:
        executable = shutil.which(tool)
        if not executable:
            record_result(
                results,
                name,
                "SKIPPED",
                f"{tool} is not installed; {workflow} remains the required CI gate.",
            )
            continue
        try:
            run(name, [executable, *arguments], results)
        except (FileNotFoundError, subprocess.CalledProcessError):
            return False
    return True


def find_git_bash() -> str:
    candidates: list[Path] = []
    if os.name == "nt":
        program_files = Path(os.environ.get("ProgramFiles", r"C:\Program Files"))
        program_files_x86 = Path(os.environ.get("ProgramFiles(x86)", r"C:\Program Files (x86)"))
        candidates.extend(
            (
                program_files / "Git" / "bin" / "bash.exe",
                program_files_x86 / "Git" / "bin" / "bash.exe",
            )
        )
    path_bash = shutil.which("bash")
    if path_bash:
        candidates.append(Path(path_bash))

    for candidate in candidates:
        if candidate.is_file():
            return str(candidate)
    raise FileNotFoundError(
        "Git Bash bash.exe was not found; install Git for Windows and retry."
    )


def command_succeeds(command: list[str]) -> bool:
    print("+ " + " ".join(command), flush=True)
    try:
        result = subprocess.run(
            command,
            cwd=REPO_ROOT,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        )
    except OSError:
        return False
    return result.returncode == 0


def run_docker_checks(
    *,
    require_docker: bool,
    bash: str,
    results: list[CheckResult],
) -> bool:
    docker = shutil.which("docker")
    if not docker:
        if require_docker:
            record_result(
                results,
                "Docker CLI availability",
                "FAIL",
                "Docker is required by --require-docker but was not found.",
            )
            return False
        record_result(
            results,
            "Docker/Compose checks",
            "SKIPPED",
            DOCKER_SKIP_MESSAGE,
        )
        return True

    record_result(results, "Docker CLI availability", "PASS", docker)

    if not command_succeeds([docker, "version"]):
        if require_docker:
            record_result(
                results,
                "Docker daemon reachability",
                "FAIL",
                "Docker is required, but the daemon is not reachable.",
            )
            return False
        record_result(
            results,
            "Docker/Compose checks",
            "SKIPPED",
            DOCKER_SKIP_MESSAGE,
        )
        return True
    record_result(results, "Docker daemon reachability", "PASS")

    if not command_succeeds([docker, "compose", "version"]):
        record_result(
            results,
            "Docker Compose availability",
            "FAIL",
            "The Docker Compose plugin is unavailable.",
        )
        return False
    record_result(results, "Docker Compose availability", "PASS")

    try:
        run(
            "Production and staging Compose model validation",
            [bash, "ops/container/validate-compose.sh", "sitbank:local-ci"],
            results,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return False
    return True


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run the repository's local CI checks.",
    )
    parser.add_argument(
        "--require-docker",
        action="store_true",
        help=(
            "Fail closed unless Docker, its daemon, Docker Compose, and both "
            "Compose model validations are available."
        ),
    )
    return parser.parse_args(argv)


def print_summary(results: list[CheckResult]) -> None:
    section("Final summary")
    for result in results:
        suffix = f" — {result.detail}" if result.detail else ""
        print(f"{result.status}: {result.name}{suffix}", flush=True)

    if any(result.status == "FAIL" for result in results):
        print("OVERALL: FAIL", flush=True)
    elif any(result.status == "SKIPPED" for result in results):
        print(
            "OVERALL: PASS (PARTIAL — one or more local checks were SKIPPED)",
            flush=True,
        )
    else:
        print(
            "OVERALL: PASS (FULL — Docker/Compose checks passed)",
            flush=True,
        )


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    require_docker = args.require_docker or os.environ.get(
        "CI_LOCAL_REQUIRE_DOCKER"
    ) == "1"
    results: list[CheckResult] = []

    section("Python/test checks")
    try:
        for name, command in PYTHON_CHECKS:
            run(name, list(command), results)

        section("Git Bash syntax checks")
        try:
            bash = find_git_bash()
        except FileNotFoundError as exc:
            record_result(results, "Git Bash availability", "FAIL", str(exc))
            raise
        record_result(results, "Git Bash availability", "PASS", bash)
        for script in discover_lint_targets("shell"):
            run(f"Syntax check {script}", [bash, "-n", script], results)

        section("Optional local static analysis")
        if not run_optional_static_analysis(results):
            print_summary(results)
            return 1
    except (FileNotFoundError, RuntimeError, subprocess.CalledProcessError):
        print_summary(results)
        return 1

    section("Docker/Compose checks")
    docker_checks_passed = run_docker_checks(
        require_docker=require_docker,
        bash=bash,
        results=results,
    )
    print_summary(results)
    return 0 if docker_checks_passed else 1


if __name__ == "__main__":
    raise SystemExit(main())
